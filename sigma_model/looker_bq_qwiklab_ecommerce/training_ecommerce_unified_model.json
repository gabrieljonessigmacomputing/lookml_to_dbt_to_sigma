        {
          "id": "event_session_facts",
          "kind": "table",
          "source": {
            "connectionId": "b4a339ca-32ef-4ea9-a8b8-1525a27322cb",
            "kind": "sql",
            "statement": "WITH session_facts AS (\n        SELECT\n           session_id\n          ,COALESCE(cast(user_id as string), ip_address) as identifier\n          ,FIRST_VALUE (created_at) OVER (PARTITION BY session_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS session_start\n          ,LAST_VALUE (created_at) OVER (PARTITION BY session_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS session_end\n          ,FIRST_VALUE (event_type) OVER (PARTITION BY session_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS session_landing_page\n          ,LAST_VALUE (event_type) OVER (PARTITION BY session_id ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS session_exit_page\n        FROM `cloud-training-demos.looker_ecomm.events`\n      )\n      SELECT * FROM session_facts\n      GROUP BY 1, 2, 3, 4, 5, 6"
          },
          "name": "event_session_facts",
          "columns": [
            {
              "id": "session_id",
              "name": "session_id",
              "formula": "[Custom SQL/session_id]"
            },
            {
              "id": "identifier",
              "name": "identifier",
              "formula": "[Custom SQL/identifier]"
            },
            {
              "id": "session_landing_page",
              "name": "session_landing_page",
              "formula": "[Custom SQL/session_landing_page]"
            },
            {
              "id": "session_exit_page",
              "name": "session_exit_page",
              "formula": "[Custom SQL/session_exit_page]"
            },
            {
              "id": "session_start",
              "name": "session_start",
              "formula": "[Custom SQL/session_start]"
            },
            {
              "id": "session_end",
              "name": "session_end",
              "formula": "[Custom SQL/session_end]"
            }
          ],
          "metrics": [
            {
              "id": "count",
              "name": "count",
              "formula": "Count()"
            }
          ],
          "relationships": [],
          "order": [
            "session_id",
            "identifier",
            "session_landing_page",
            "session_exit_page",
            "session_start",
            "session_end"
          ]
        },
        {
          "id": "event_session_funnel",
          "kind": "table",
          "source": {
            "connectionId": "b4a339ca-32ef-4ea9-a8b8-1525a27322cb",
            "kind": "sql",
            "statement": "SELECT\n          session_id\n        , MIN(\n            CASE WHEN\n              event_type = 'Product'\n              THEN created_at\n              ELSE NULL END\n            ) as event1_time\n        , MIN(\n            CASE WHEN\n              event_type = 'Cart'\n              THEN created_at\n              ELSE NULL END\n            ) as event2_time\n        , MIN(\n            CASE WHEN\n              event_type = 'Purchase'\n              THEN created_at\n              ELSE NULL END\n            ) as event3_time\n      FROM `cloud-training-demos.looker_ecomm.events`\n      GROUP BY 1"
          },
          "name": "event_session_funnel",
          "columns": [
            {
              "id": "session_id",
              "name": "session_id",
              "formula": "[Custom SQL/session_id]"
            },
            {
              "id": "event1_before_event2",
              "name": "event1_before_event2",
              "formula": "[event1_time] < [event2_time]"
            },
            {
              "id": "event2_before_event3",
              "name": "event2_before_event3",
              "formula": "[event2_time] < [event3_time]"
            },
            {
              "id": "time_in_funnel",
              "name": "time_in_funnel",
              "formula": "datediff(min, [event1_raw],COALESCE([event3_raw],[event2_raw]))"
            },
            {
              "id": "event1",
              "name": "event1",
              "formula": "[Custom SQL/event1_time]"
            },
            {
              "id": "event2",
              "name": "event2",
              "formula": "[Custom SQL/event2_time]"
            },
            {
              "id": "event3",
              "name": "event3",
              "formula": "[Custom SQL/event3_time]"
            }
          ],
          "metrics": [
            {
              "id": "count",
              "name": "count",
              "formula": "Count()"
            },
            {
              "id": "count_sessions",
              "name": "count_sessions",
              "formula": "CountDistinct([session_id])"
            },
            {
              "id": "count_sessions_event1",
              "name": "count_sessions_event1",
              "formula": "CountDistinct([session_id])"
            },
            {
              "id": "count_sessions_event12",
              "name": "count_sessions_event12",
              "formula": "CountDistinct([session_id])"
            },
            {
              "id": "count_sessions_event123",
              "name": "count_sessions_event123",
              "formula": "CountDistinct([session_id])"
            }
          ],
