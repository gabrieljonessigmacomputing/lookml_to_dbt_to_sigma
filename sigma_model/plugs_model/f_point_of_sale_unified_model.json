            "kind": "warehouse-table",
            "path": [
              "RETAIL",
              "PLUGS_ELECTRONICS",
              "F_POINT_OF_SALE"
            ]
          },
          "name": "f_point_of_sale",
          "columns": [
            {
              "id": "order_number",
              "formula": "${TABLE}.\"Order Number\""
            },
            {
              "id": "product_key",
              "formula": "${TABLE}.\"Product Key\""
            },
            {
              "id": "sales_quantity",
              "formula": "${TABLE}.\"Sales Quantity\""
            },
            {
              "id": "sales_amount",
              "formula": "${TABLE}.\"Sales Amount\""
            },
            {
              "id": "cost_amount",
              "formula": "${TABLE}.\"Cost Amount\""
            },
            {
              "id": "row_count",
              "formula": "[row_count]"
            },
            {
              "id": "total_sales_amount",
              "formula": "${sales_amount} * ${sales_quantity}"
            },
            {
              "id": "total_cost_amount",
              "formula": "${cost_amount} * ${sales_quantity}"
            },
            {
              "id": "gross_profit_amount",
              "formula": "${total_sales_amount} - ${total_cost_amount}"
            },
            {
              "id": "gross_profit_margin",
              "formula": "1.0 * ${gross_profit_amount} / NULLIF(${total_sales_amount}, 0)"
            }
          ],
