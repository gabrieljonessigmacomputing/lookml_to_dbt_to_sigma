# Copy to .env and set real values. Do not commit .env with secrets.
# Generated .env is created by setup.sh; this file is the reference for all variables.

# LookML / conversion
LOOKML_DIR=lookml
MANIFEST_DATABASE=RETAIL
MANIFEST_SCHEMA=PLUGS_ELECTRONICS
MANIFEST_TABLE_PREFIX=
MANIFEST_TABLE_SUFFIX=

# Sigma API (for create_model.py)
API_URL=https://api.sigmacomputing.com/v2
SIGMA_DOMAIN=my-org.sigmacomputing.com
API_CLIENT_ID=your-client-id
API_SECRET=your-secret

# Connections: default + per-project (CONNECTION_ID_<FOLDER>, e.g. CONNECTION_ID_PLUGS)
CONNECTION_ID_DEFAULT=your-default-connection-uuid
# CONNECTION_ID_PLUGS=uuid-for-plugs
# CONNECTION_ID_LOOKER_BQ_QWIKLAB_ECOMMERCE=uuid-for-qwiklab

# Sigma folder for created data models
SIGMA_FOLDER_ID=your-sigma-folder-id

# Optional (create_model.py)
# SIGMA_CLIENT_ID=    # preferred over API_CLIENT_ID
# SIGMA_CLIENT_SECRET= # preferred over API_SECRET
# SIGMA_API_BASE_URL=https://api.sigmacomputing.com
# CREATE_MODEL_VERBOSE=1

# Optional (setup / workflows)
MODE=initial
USER_FRIENDLY_COLUMN_NAMES=true
TEST_FLAG=true
FROM_CI_CD=false
